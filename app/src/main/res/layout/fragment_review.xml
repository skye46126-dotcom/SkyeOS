<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingTop="34dp">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_review_period"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#22FFFFFF"
        app:tabIndicatorColor="@color/lifeBlue"
        app:tabSelectedTextColor="@color/lifeBlue"
        app:tabTextColor="@color/textSecondary">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Day" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Week" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Month" />
    </com.google.android.material.tabs.TabLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title & Date Range -->
            <TextView
                android:id="@+id/tv_review_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/textPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                tools:text="Weekly Report (Mar 1 - Mar 7)" />

            <TextView
                android:id="@+id/tv_review_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                tools:text="Key changes and suggested actions for this window" />

            <!-- AI Summary Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.LifeOS.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 Snapshot"
                        android:textStyle="bold"
                        android:textColor="@color/lifeBlueDark"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_ai_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textPrimary"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="You spent 45 hours, earned ¥3,200. Keep it up!" />

                    <TextView
                        android:id="@+id/tv_cost_debt_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        tools:text="Actual ¥80/h | Ideal ¥120/h | Time debt ¥40/h" />

                    <TextView
                        android:id="@+id/tv_trend_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        tools:text="MoM: Income +12.0% | Expense -8.2% | Work time +5.0%" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_ai_assist_metric"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="AI assist 35.0%" />

                        <TextView
                            android:id="@+id/tv_work_eff_metric"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Work efficiency 7.80/10" />

                        <TextView
                            android:id="@+id/tv_learning_eff_metric"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Learning efficiency 8.20/10" />
                    </LinearLayout>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_trend_detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_trend_income"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Income Details"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_trend_expense"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expense Details" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_trend_work"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Work Time Details" />
                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:id="@+id/tv_trend_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        tools:text="Income: current ¥1200 vs previous ¥900" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_trend_detail_records"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="56dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Time Allocation"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Time Chart Container (Using RecyclerView for simplicity of bars) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.LifeOS.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_time_allocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:padding="8dp"
                    android:clipToPadding="false"/>
                    
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏆 ROI Leaderboard"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.LifeOS.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_top_projects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:padding="8dp"
                    android:clipToPadding="false"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚨 Time Sinkholes (High Time, Low ROI)"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.LifeOS.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_sinkhole_projects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="60dp"
                    android:padding="8dp"
                    android:clipToPadding="false"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Key Events"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_key_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💰 Income History"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.LifeOS.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_income_history_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"
                        tools:text="12 income records | Total ¥8,800.00" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_income_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📒 History Ledger"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.LifeOS.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_history_filter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_history_all"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_history_income"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Income" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_history_expense"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expense" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_history_time"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_history_learning"
                            style="@style/Widget.LifeOS.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Learning" />
                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:id="@+id/tv_history_ledger_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        tools:text="All 36 records" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_history_ledger"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏷️ Tag Board"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.LifeOS.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Top Time Tags"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_tag_time_metrics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="50dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Top Expense Tags"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_tag_expense_metrics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:minHeight="50dp" />

                    <TextView
                        android:id="@+id/tv_tag_detail_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        tools:text="Tag details: Learning (time)"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_tag_detail_records"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="80dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
