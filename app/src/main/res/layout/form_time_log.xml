<?xml version="1.0" encoding="utf-8"?>
<!-- Manual: Time Log form card -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- Start Time -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_time_start"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="开始时间 (yyyy-MM-dd HH:mm)"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_time_start"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:cursorVisible="false"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- End Time -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_time_end"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="结束时间 (yyyy-MM-dd HH:mm)"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_time_end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:cursorVisible="false"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Category -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_time_category"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="分类"
            android:layout_marginBottom="10dp">
            <AutoCompleteTextView
                android:id="@+id/acv_time_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Project Allocation -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_time_project"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="绑定项目（点击下方选择）"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_time_project"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Project Quick-Pick chips container -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_projects_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:singleSelection="false"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="标签（可多选）"
            android:textSize="13sp"
            android:textColor="@color/textSecondary"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_tags_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:singleSelection="false"/>

        <!-- Note -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_time_note"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="备注"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_time_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Submit -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_time"
            style="@style/Widget.LifeOS.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="记录时间"/>

    </LinearLayout>
</ScrollView>
