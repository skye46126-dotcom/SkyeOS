<?xml version="1.0" encoding="utf-8"?>
<!-- Manual: Income form -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp">

        <!-- Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_income_amount"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="金额（元）"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_income_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Type -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_income_type"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="类型"
            android:layout_marginBottom="10dp">
            <AutoCompleteTextView
                android:id="@+id/acv_income_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Source -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_income_source"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="来源名称"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_income_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Project Allocation -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_income_project"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="绑定项目（可选）"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_income_project"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_projects_income"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:singleSelection="false"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="标签（可多选）"
            android:textSize="13sp"
            android:textColor="@color/textSecondary"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_tags_income"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="false"/>

        <!-- Submit -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_income"
            style="@style/Widget.LifeOS.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="记录收入"/>

    </LinearLayout>
</ScrollView>
