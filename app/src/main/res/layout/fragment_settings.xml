<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="60dp"
        android:paddingBottom="104dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/textPrimary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_subtitle"
            android:textColor="@color/textSecondary"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.LifeOS.TextInputLayout.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_language_hint"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/et_app_language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Cloud Sync Section Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☁️ Cloud Backup"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <!-- Server URL input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_server_url"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Server URL (https://...)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_server_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:imeOptions="actionNext"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- API Key input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_api_key"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API Key"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textVisiblePassword"
                android:imeOptions="actionNext"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Device ID input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_device_id"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device ID (e.g. android-self)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_device_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionDone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save Config button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_config"
            style="@style/Widget.LifeOS.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/settings_save_config"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Cost logic has moved out of Settings. Use Cost Management for ideal rate, monthly baseline, recurring costs, and capex."
            android:textColor="@color/textSecondary"
            android:textSize="13sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_cost_management"
            style="@style/Widget.LifeOS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:text="@string/settings_open_cost_management"/>

        <!-- AI config section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 AI Parsing API"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.LifeOS.TextInputLayout.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI Provider (custom / deepseek / siliconflow)"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/et_ai_provider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI Base URL (OpenAI-compatible, e.g. https://api.openai.com)"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_ai_base_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:imeOptions="actionNext"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI API Key"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_ai_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textVisiblePassword"
                android:imeOptions="actionNext"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI Model (e.g. gpt-4o-mini / deepseek-chat)"
            android:layout_marginBottom="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_ai_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionDone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AI System Prompt (customizable)"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_ai_system_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="4"
                android:maxLines="6"
                android:paddingTop="16dp"
                android:inputType="textMultiLine"
                android:gravity="top|start"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_ai"
                style="@style/Widget.LifeOS.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:strokeColor="@color/lifeBlue"
                android:textColor="@color/lifeBlue"
                android:text="Test Connection (Ping)"/>
            <TextView
                android:id="@+id/tv_ai_test_result"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:text=""/>
        </LinearLayout>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_upload_backup"
            style="@style/Widget.LifeOS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="⬆ Upload Latest Backup"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_list_backups"
            style="@style/Widget.LifeOS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📋 List Remote Backups"
            android:layout_marginBottom="16dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp"/>

        <!-- Restore section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 Restore Backup"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <!-- Download filename input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_download_filename"
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Filename (copy from list)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_download_filename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_download_restore"
            style="@style/Widget.LifeOS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="⬇ Download &amp; Restore"
            android:layout_marginBottom="16dp"/>

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/glassCardBg"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status Log"
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:id="@+id/tv_cloud_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready"
                    android:textColor="@color/textPrimary"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/tv_remote_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/textSecondary"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_tag_management"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.LifeOS.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tag name"
            android:layout_marginBottom="10dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_tag_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.LifeOS.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:hint="emoji">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_tag_emoji"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.LifeOS.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="scope">
                <AutoCompleteTextView
                    android:id="@+id/et_tag_scope"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_tag"
            style="@style/Widget.LifeOS.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/settings_create_tag"
            android:layout_marginBottom="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/glassCardBg"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp">

            <LinearLayout
                android:id="@+id/layout_tag_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
